//
// PF probe — input.color PACKED DEFVAL (#9)
// Purpose: COMPILE / UI golden for input.color defval lowering. Pre-fix a
// color defval lowered to "0" (always transparent-black) and routed through
// get_input_int (int32 overflow on packed ARGB); post-fix it lowers to a
// packed 0xAARRGGBB int64 literal and routes through get_input_int64.
//
// NOTE: color inputs are cosmetic — they never affect the trade list, so
// this is NOT a TV-parity (trade-list) probe. Validate by inspecting the
// generated.cpp (the get_input_int64 call with the packed defval) and/or the
// plotted color. The codegen unit tests already pin the lowering
// (tests/test_codegen_input_getters.py, tests/test_input_time_int64.py).
//
//@version=6
strategy("input.color packed defval", overlay=true, initial_capital=1000000, currency=currency.USD, process_orders_on_close=false, default_qty_type=strategy.fixed, default_qty_value=1)

// Three defval shapes the lowering must handle:
cConst = input.color(color.red,        "Const color")    // -> pine_color::red (int64)
cHex6  = input.color(#00e676,          "Hex #RRGGBB")    // -> 0xff00e676LL (opaque)
cHex8  = input.color(#00ff0080,        "Hex #RRGGBBAA")  // -> 0x8000ff00LL (alpha 0x80)
cNew   = input.color(color.new(color.blue, 50), "Builder")

// Trivial trade so the strategy compiles to a runnable .so.
if bar_index == 10
    strategy.entry("Long", strategy.long)

plot(close, color=cHex6)
plot(close, color=cHex8)
