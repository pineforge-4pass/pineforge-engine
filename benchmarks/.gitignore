# Local benchmark working state — never commit
.venv/
node_modules/
package-lock.json
_workdir/
__pycache__/
*.pyc

# Compiled C++ runner binary (rebuilt by run_all.sh)
runners/run_pineforge_canonical
runners/_smoke_pinets.mjs

# Cached intermediate output (regenerated by run_all.sh)
strategies/*/_pynecore_raw_trades.csv
strategies/*/_pyne_*.csv
strategies/*/__pycache__/

# Per-strategy stats CSV is regenerated each run; only trade lists are tracked
strategies/*/pynecore_stats.csv

# Cloud-compile temp/backup artefacts
strategies/*/strategy_pyne.py.bak
strategies/*/strategy_pyne.toml

# Compare.py output is checked in to results/
