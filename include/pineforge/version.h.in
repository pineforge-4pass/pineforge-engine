/* PineForge version header — generated by CMake from version.h.in.
 * Do not edit by hand. Source of truth: VERSION + git tag.
 */

#ifndef PINEFORGE_VERSION_H
#define PINEFORGE_VERSION_H

#define PINEFORGE_VERSION_MAJOR   @PINEFORGE_VERSION_MAJOR@
#define PINEFORGE_VERSION_MINOR   @PINEFORGE_VERSION_MINOR@
#define PINEFORGE_VERSION_PATCH   @PINEFORGE_VERSION_PATCH@

/* "MAJOR.MINOR.PATCH" — for ABI / find_package(PineForge X.Y) checks. */
#define PINEFORGE_VERSION_STRING  "@PINEFORGE_VERSION_MMP@"

/* "MAJOR.MINOR.PATCH[-N-gSHA[-dirty]]" — full git-derived descriptor.
 * Identical to PINEFORGE_VERSION_STRING for tarball / non-git builds. */
#define PINEFORGE_VERSION_FULL    "@PINEFORGE_VERSION_FULL@"

/* Short git sha (7 chars) or "unknown" if built outside a git checkout. */
#define PINEFORGE_GIT_SHA         "@PINEFORGE_VERSION_GIT_SHA@"

#endif /* PINEFORGE_VERSION_H */
